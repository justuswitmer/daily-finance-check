# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=+1XXXXXXXXXX
TWILIO_MESSAGING_SERVICE_SID=

# Created by `npm run setup-conversation`
CONVERSATION_SID=

# Schedule (cron expression, default 7am CT)
CRON_SCHEDULE=0 7 * * *
TZ=America/Chicago

# Server
PORT=3000
