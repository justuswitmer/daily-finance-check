# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: Plaid accounts in .env (suffix can be ONE, TWO, 1, 2, etc.)
# Add one token + one or more account ids per suffix.
# PLAID_ACCOUNT_LABEL_ONE=Capital One
# PLAID_ACCOUNT_ACCESS_TOKEN_ONE=access-production-...
# PLAID_ACCOUNT_ACCESS_ID_ONE=account-id-1
# Or multiple ids (comma-separated):
# PLAID_ACCOUNT_ACCESS_IDS_ONE=account-id-1,account-id-2

# Email
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# Schedule (cron expression, default 7am CT)
CRON_SCHEDULE=0 7 * * *
TZ=America/Chicago
ENABLE_INTERNAL_CRON=true

# External trigger security token for POST /run
RUN_TOKEN=

# Server
PORT=3000
